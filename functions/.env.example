# Spotify OAuth app credentials (backend only)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Optional hardening: force a single redirect URI accepted by backend
SPOTIFY_REDIRECT_URI=keepsyn://spotify-callback

# YouTube OAuth app credentials (backend only)
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret

# Optional backend defaults
SYNC_API_REGION=us-central1

# YouTube quota guard (estimado interno, no reemplaza metricas reales de GCP)
SYNC_YOUTUBE_DAILY_QUOTA_BUDGET=9000
SYNC_YOUTUBE_MIN_QUOTA_BUFFER=300

