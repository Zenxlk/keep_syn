# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Ignorar archivos de configuración de servicios de Google
android/app/google-services.json
google-services.json
ios/Runner/GoogleService-Info.plist
android/app/GoogleService-Info.plist

# Firebase — generado por FlutterFire CLI, contiene API keys por plataforma
# Regenerar con: flutterfire configure
lib/firebase_options.dart

# Android signing — nunca versionar credenciales de firma
android/app/*.keystore
android/app/*.jks
android/key.properties

# iOS/macOS distribution
*.mobileprovision
*.p12
*.cer

# Dependencias
node_modules/

# Archivos de logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Archivos de configuración del editor
.idea
.vscode

# Archivos de registro
macos/Flutter/GeneratedPluginRegistrant.swift

# Env files para Flutter (usar ejemplos versionados)
/env/*.json
!/env/*.example.json

# Env files genéricos locales
.env
.env.*

# Entornos locales de Postman
docs/postman/*.local.postman_environment.json

