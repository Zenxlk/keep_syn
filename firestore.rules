rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. USUARIOS
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. ALLOWLIST — solo backend (Admin SDK bypasses rules)
    match /allowlist/{document=**} {
      allow read, write: if false;
    }

    // 3. LOGS DE ERRORES — solo backend
    match /app_logs/{document=**} {
      allow read, write: if false;
    }

    // 4. SYNC JOBS
    // resource == null cubre el instante de race condition en que el doc aún
    // no propagó al cliente tras ser escrito por el backend.
    match /sync_jobs/{jobId} {
      allow read: if request.auth != null
        && (resource == null || request.auth.uid == resource.data.uid);
      allow write: if false;
    }

    match /sync_job_events/{eventId} {
      allow read: if request.auth != null
        && (resource == null || request.auth.uid == resource.data.uid);
      allow write: if false;
    }

    // 5. SECRETS DE INTEGRACIÓN — solo backend
    match /integration_secrets/{document=**} {
      allow read, write: if false;
    }

    // 6. ESTADO DE INTEGRACIONES — solo lectura del propio usuario
    match /user_integrations/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // 7. CACHE DE BÚSQUEDA — solo backend
    match /track_search_cache/{document=**} {
      allow read, write: if false;
    }

    // 8. QUOTA CONTROLS — solo backend
    match /sync_quota_controls/{document=**} {
      allow read, write: if false;
    }

  }
}
