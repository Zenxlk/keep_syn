{
  "info": {
    "name": "KeepSyn Sync API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Coleccion para probar endpoints de sincronizacion en Cloud Functions"
  },
  "item": [
    {
      "name": "1 - Crear Job",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{idToken}}",
              "type": "string"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/v1/sync/jobs",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "sync",
            "jobs"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sourcePlatform\": \"spotify\",\n  \"targetPlatform\": \"youtube\",\n  \"sourcePlaylistId\": \"pl_123\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('Contrato estandar', function () {",
              "  pm.expect(json).to.have.property('status');",
              "  pm.expect(json).to.have.property('message');",
              "});",
              "if (json.data && json.data.jobId) {",
              "  pm.environment.set('jobId', json.data.jobId);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2 - Obtener Estado Job",
      "request": {
        "method": "GET",
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{idToken}}",
              "type": "string"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/v1/sync/jobs/{{jobId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "sync",
            "jobs",
            "{{jobId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('Retorna estado de job', function () {",
              "  pm.expect(json.data).to.have.property('state');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "3 - Cancelar Job",
      "request": {
        "method": "POST",
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{idToken}}",
              "type": "string"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/v1/sync/jobs/{{jobId}}/cancel",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "sync",
            "jobs",
            "{{jobId}}",
            "cancel"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('Job cancelado o controlado', function () {",
              "  pm.expect(json).to.have.property('status');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "4 - Ultimo Job",
      "request": {
        "method": "GET",
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{idToken}}",
              "type": "string"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/v1/sync/jobs/last",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "sync",
            "jobs",
            "last"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('Contrato estandar', function () {",
              "  pm.expect(json).to.have.property('status');",
              "  pm.expect(json).to.have.property('message');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}

